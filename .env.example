# STT Final Summary - Environment Configuration
# Copy this file to .env and fill in your actual API keys
# IMPORTANT: Never commit .env file to git!

# ========================================
# Azure Speech Services (STT Model 1)
# ========================================
AZURE_SPEECH_KEY=your-azure-speech-key-here
AZURE_SPEECH_REGION=southeastasia
AZURE_SPEECH_LANGUAGE=th-TH

# ========================================
# External Whisper API (STT Model 2)
# Docker/Server based Whisper transcription
# ========================================
EXTERNAL_WHISPER_SERVER_IP=192.168.10.19
EXTERNAL_WHISPER_PORT=8100
EXTERNAL_WHISPER_ENDPOINT=http://192.168.10.19:8100/v1/media/transcribe

# ========================================
# MAI Transcribe API (STT Model 3)
# Azure Speech Services - MAI Endpoint
# ========================================
MAI_SPEECH_KEY=your-mai-speech-api-key-here
MAI_SPEECH_ENDPOINT=https://mai-speech.cognitiveservices.azure.com/
MAI_SPEECH_LANGUAGE=th-TH

# ========================================
# Google Cloud Speech-to-Text (Optional)
# ========================================
# STT_MODEL4_KEY=your-google-cloud-api-key-here

# ========================================
# Azure OpenAI (For AI-based transcript comparison)
# ========================================
AZURE_OPENAI_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DEPLOYMENT_NAME=your-deployment-name-here
AZURE_SPEECH_LANGUAGE=th-TH

# ========================================
# OpenAI API (Optional for Summarization)
# ========================================
# OPENAI_API_KEY=your-openai-api-key-here

# ========================================
# Optional Configuration
# ========================================
LOG_LEVEL=INFO
PROCESSING_TIMEOUT=300
MAX_FILE_SIZE=2048
OUTPUT_FORMAT=markdown
LANGUAGE_CODE=th
ENABLE_PREPROCESSING=true
ENABLE_SUMMARIZATION=true
SUMMARY_LANGUAGE=th
