# ── Server ────────────────────────────────────────────────────
PORT=9100
PUBLIC_BASE_URL=http://localhost:9100
AUTH_SECRET=change-me-before-production
AUTH_TTL_HOURS=12
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=123456789

# PostgreSQL
PGHOST=db
PGPORT=5432
PGDATABASE=betimes_apps
PGUSER=btimes
PGPASSWORD=btimes123

# ── Azure Speech (STT / Azure token) ─────────────────────────
AZURE_KEY=
AZURE_REGION=southeastasia

# ── MAI Speech ────────────────────────────────────────────────
MAI_KEY=
MAI_ENDPOINT=https://mai-speech.cognitiveservices.azure.com/

# ── Azure OpenAI (Summary + Correction) ──────────────────────
OAI_KEY=
OAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
OAI_DEPLOY=gpt-4o-mini-2

# ── Whisper ───────────────────────────────────────────────────
# azure = use Azure OpenAI Whisper deployment
# local = use tested Whisper server at 192.168.10.19:9000
ENABLE_WHISPER=true
WHISPER_MODE=local
WHISPER_DEPLOY=whisper
WHISPER_ENDPOINT=http://192.168.10.19:9000
WHISPER_PROXY_SECRET=change-me-before-public-proxy

# Local whisper container settings (only if WHISPER_MODE=local)
WHISPER_MODEL=medium
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ── Azure Document Intelligence (OCR) ────────────────────────
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=
